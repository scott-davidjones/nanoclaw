SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
OLLAMA_HOST=
ASSISTANT_HAS_OWN_NUMBER=
OPENAI_API_KEY=
# MCP memory server — env-conditional fallback. Prefer dropping a file in
# brain/mcp.d/ (or any path on NANOCLAW_MCP_CONFIG_PATH) so the URL works
# from host-side Claude Code, agent containers, and remote dev machines
# without a config split. Pick a hostname reachable from every consumer.
MCP_MEMORY_URL=http://casa.in-line.studio:3456/mcp
# Brain repo (studio engineering standards) — mounted read-only at /workspace/brain
BRAIN_ROOT=
# Set to 1 to dump the full SDK BetaMessage JSON per assistant turn into the
# container-*.log files. Useful when diagnosing LiteLLM response translation
# issues (empty text blocks, redactions, unexpected content types).
LOG_RAW_LLM_RESPONSES=
